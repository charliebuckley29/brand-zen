      "id": "2",
      "name": "Get Brand Info",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        400,
        300
      ]
    },
    {
      "parameters": {
        "functionCode": "\nconst fullText = $json[\"full_text\"] || $json[\"content_snippet\"] || \"\";\nconst keyword = $node[\"Get Brand Info\"].json[0];\nconst brand = keyword.brand_name.toLowerCase();\nconst variants = keyword.variants || [];\n\nconst terms = [brand, ...variants.map(v => v.toLowerCase())];\n\nlet matchIndex = -1;\nfor (const term of terms) {\n  const idx = fullText.toLowerCase().indexOf(term);\n  if (idx !== -1) {\n    matchIndex = idx;\n    break;\n  }\n}\n\nconst maxChars = 2000;\nlet truncated = fullText;\nif (matchIndex !== -1) {\n  const start = Math.max(0, matchIndex - maxChars / 2);\n  const end = Math.min(fullText.length, matchIndex + maxChars / 2);\n  truncated = fullText.slice(start, end);\n} else {\n  truncated = fullText.slice(0, maxChars);\n}\n\nreturn [{\n  truncated,\n  brand_name: keyword.brand_name,\n  mention_id: $json[\"id\"]\n}];\n"
      },
      "id": "3",
      "name": "Truncate Around Brand",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
