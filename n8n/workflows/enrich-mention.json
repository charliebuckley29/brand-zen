    },
    {
      "parameters": {
        "model": "gpt-4o",
        "prompt": "\nAnalyze this brand mention related to \"{{ $json[\"brand_name\"] }}\". Return:\n\n- Sentiment (positive, negative, or neutral)\n- Cleaned text (remove irrelevant parts)\n- One-line summary\n\nMention:\n{{ $json[\"truncated\"] }}\n\nRespond in this JSON format:\n\n{\n  \"sentiment\": \"positive\",\n  \"cleaned_text\": \"...\",\n  \"summary\": \"...\"\n}\n",
        "maxTokens": 300
      },
